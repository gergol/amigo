{
  "name": "amigo",
  "version": "0.1.0",
  "description": "Spanish learning app (A1/A2) for German speakers — terminal trainer",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "tsx src/cli/main.ts",
    "build:content": "tsx scripts/build-content.ts",
    "predev": "npm run build:content",
    "dev": "vite --host",
    "prebuild": "npm run build:content",
    "build": "vite build",
    "preview": "vite preview --host",
    "test": "node --import tsx --test test/*.test.ts",
    "typecheck": "tsc --noEmit && tsc -p src/web/tsconfig.json --noEmit",
    "validate": "tsx src/cli/validate.ts"
  },
  "dependencies": {
    "preact": "^10.29.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.5",
    "@types/node": "^26.1.1",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-pwa": "^1.3.0"
  }
}
